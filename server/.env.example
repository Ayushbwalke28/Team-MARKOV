## Database (Supabase Postgres)
# Runtime database URL.
# - For most setups, use Supabase *direct* connection (port 5432) + SSL here.
# - If you use Supabase pgBouncer pooler (port 6543) for runtime, put it here and
#   set DATABASE_URL_MIGRATE to the *direct* 5432 URL for Prisma CLI.
DATABASE_URL="postgresql://postgres:password@localhost:5432/postgres?sslmode=require"

# Optional, recommended when DATABASE_URL uses Supabase pooler:
# postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL_MIGRATE=""

## Auth
JWT_ACCESS_SECRET="change_me_access"
JWT_REFRESH_SECRET="change_me_refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"
BCRYPT_ROUNDS="12"

## Cloudinary
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

## Verification
VERIFICATION_MAX_ATTEMPTS=3
VERIFICATION_RAW_DATA_RETENTION_HOURS=0
VERIFICATION_FACE_MATCH_THRESHOLD=0.85
VERIFICATION_FACE_REVIEW_THRESHOLD=0.70
VERIFICATION_MANUAL_REVIEW_SLA_HOURS=24
VERIFICATION_WEBHOOK_URL=""
VERIFICATION_WEBHOOK_SECRET=""

ADMIN_EMAIL="[EMAIL_ADDRESS]"
ADMIN_PASSWORD="[PASSWORD]"