generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRoleType {
  candidate
  company_owner
  admin
}

enum ClaimStatus {
  pending
  domain_otp_sent
  document_uploaded
  gst_validated
  under_admin_review
  approved
  rejected
  withdrawn
}

enum ClaimVerificationMethod {
  domain_email
  business_document
  gst_registration
  admin_review
}

enum CompanyRoleType {
  owner
  founder
  authorized
  employee
  viewer
}

enum Gender {
  male
  female
  non_binary
  other
  prefer_not_to_say
}

enum OpportunityType {
  job
  internship
  freelance
}

enum OpportunityMode {
  online
  onsite
  hybrid
}

enum OpportunityStatus {
  open
  closed
}

enum AuthorType {
  user
  company
}

enum VerificationStatus {
  pending
  document_uploaded
  face_captured
  processing
  passed
  failed
  manual_review
  locked
}

enum DocumentType {
  passport
  drivers_license
  aadhaar
  pan_card
  national_id
}

model User {
  id               String  @id
  email            String  @unique
  name             String
  passwordHash     String?
  googleId         String? @unique
  refreshTokenHash String?
  verified         Boolean @default(false)
  avatarUrl        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile                     UserProfile?
  roles                       UserRole[]
  company                     Company?
  organizedEvents             Event[]                      @relation("OrganizedEventsUser")
  eventBookings               EventBooking[]
  posts                       Post[]                       @relation("UserPosts")
  postLikes                   PostLike[]
  postComments                PostComment[]
  sentConnections             Connection[]                 @relation("SentConnections")
  receivedConnections         Connection[]                 @relation("ReceivedConnections")
  verificationSessions        VerificationSession[]
  companyVerificationSessions CompanyVerificationSession[]
  investorProfile             InvestorProfile?
  dealRooms                   DealRoom[]
  fraudReports                FraudReport[]
  ownershipClaims             CompanyOwnershipClaim[]      @relation("ClaimantClaims")
  companyRoles                CompanyRole[]

  @@index([email])
}

model UserRole {
  userId String
  role   UserRoleType

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, role])
  @@index([role])
}

model UserProfile {
  userId String @id

  // Basic info
  fullName String?
  about    String?

  // Media (store URLs/paths; actual file storage is handled elsewhere)
  avatarUrl String?
  bannerUrl String?

  // Demographics
  dob      DateTime?
  gender   Gender?
  pronouns String?

  education    Education[]
  experience   Experience[]
  certificates Certificate[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Education {
  id String @id @default(cuid())

  profileUserId String
  profile       UserProfile @relation(fields: [profileUserId], references: [userId], onDelete: Cascade)

  institution  String
  degree       String?
  fieldOfStudy String?
  startDate    DateTime?
  endDate      DateTime?
  grade        String?
  description  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileUserId])
}

model Experience {
  id String @id @default(cuid())

  profileUserId String
  profile       UserProfile @relation(fields: [profileUserId], references: [userId], onDelete: Cascade)

  title          String
  company        String?
  location       String?
  employmentType String?
  startDate      DateTime?
  endDate        DateTime?
  isCurrent      Boolean   @default(false)
  description    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileUserId])
}

model Certificate {
  id String @id @default(cuid())

  profileUserId String
  profile       UserProfile @relation(fields: [profileUserId], references: [userId], onDelete: Cascade)

  title          String
  issuer         String?
  issueDate      DateTime?
  expirationDate DateTime?
  credentialId   String?
  credentialUrl  String?
  description    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileUserId])
}

model Company {
  id                      String                    @id @default(cuid())
  name                    String                    @unique
  ownerId                 String                    @unique
  location                String?
  startYear               Int?
  description             String?
  size                    String?
  domain                  String?
  websiteDomain           String?                   @unique
  logoUrl                 String?
  verificationStatus      CompanyVerificationStatus @default(pending)
  taxId                   String?
  registrationDocumentUrl String?
  incorporationCertUrl    String?
  gstin                   String?
  cinNumber               String?
  verifiedAt              DateTime?

  owner                       User                         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  opportunities               Opportunity[]
  organizedEvents             Event[]                      @relation("OrganizedEventsCompany")
  posts                       Post[]                       @relation("CompanyPosts")
  companyVerificationSessions CompanyVerificationSession[]
  investmentProfile           InvestmentProfile?
  dealRooms                   DealRoom[]
  ownershipClaims             CompanyOwnershipClaim[]
  companyRoles                CompanyRole[]
  fundingRounds               FundingRound[]
  trustScore                  Float?                       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model Opportunity {
  id                   String            @id @default(cuid())
  companyId            String
  type                 OpportunityType
  mode                 OpportunityMode
  status               OpportunityStatus @default(open)
  payment              String?
  postName             String
  description          String?
  registrationDeadline DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model Post {
  id              String     @id @default(cuid())
  text            String
  media           String[]
  mediaUrl        String?
  authorType      AuthorType
  authorUserId    String?
  authorCompanyId String?

  authorUser    User?    @relation("UserPosts", fields: [authorUserId], references: [id], onDelete: Cascade)
  authorCompany Company? @relation("CompanyPosts", fields: [authorCompanyId], references: [id], onDelete: Cascade)

  likes    PostLike[]
  comments PostComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorUserId])
  @@index([authorCompanyId])
  @@index([createdAt])
}

model PostLike {
  id     String @id @default(cuid())
  postId String
  userId String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model PostComment {
  id     String @id @default(cuid())
  postId String
  userId String
  text   String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([userId])
}

enum OrganizerType {
  individual
  company
}

enum EventMode {
  online
  offline
  hybrid
}

model Event {
  id                 String        @id @default(cuid())
  title              String
  description        String?
  category           String?
  organizerType      OrganizerType
  organizerUserId    String?
  organizerCompanyId String?
  schedule           DateTime
  fees               Float         @default(0)
  mode               EventMode
  venue              String?
  onlinePlatform     String?
  bannerUrl          String?
  status             EventStatus   @default(draft)
  trustScore         Float?        @default(0)
  payoutStatus       PayoutStatus  @default(held)

  organizerUser    User?          @relation("OrganizedEventsUser", fields: [organizerUserId], references: [id], onDelete: Cascade)
  organizerCompany Company?       @relation("OrganizedEventsCompany", fields: [organizerCompanyId], references: [id], onDelete: Cascade)
  bookings         EventBooking[]
  fraudReports     FraudReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizerUserId])
  @@index([organizerCompanyId])
}

model EventBooking {
  id      String @id @default(cuid())
  eventId String
  userId  String

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  paymentId     String?
  escrowStatus  EscrowStatus  @default(pending)
  checkInStatus CheckInStatus @default(pending)
  refundStatus  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

enum ConnectionStatus {
  pending
  accepted
  declined
}

model Connection {
  id         String           @id @default(cuid())
  senderId   String
  receiverId String
  status     ConnectionStatus @default(pending)

  sender   User @relation("SentConnections", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedConnections", fields: [receiverId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
}

model VerificationSession {
  id           String             @id @default(cuid())
  userId       String
  status       VerificationStatus @default(pending)
  documentType DocumentType?

  // OCR extracted fields (stored temporarily for review, cleared after)
  ocrName     String?
  ocrDob      String?
  ocrIdNumber String?
  ocrExpiry   String?
  ocrAddress  String?

  // Document validation results
  documentValid    Boolean?
  documentExpired  Boolean?
  documentBlurry   Boolean?
  documentTampered Boolean?

  // Face verification results
  faceMatchScore Float?
  livenessPass   Boolean?

  // Overall result
  confidenceScore Float?
  failureReason   String?
  attemptNumber   Int     @default(1)

  // Consent tracking
  consentGiven     Boolean   @default(false)
  consentTimestamp DateTime?

  // Data retention
  rawDataDeletedAt DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  manualReview ManualReview?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model ManualReview {
  id                    String    @id @default(cuid())
  verificationSessionId String    @unique
  reason                String
  reviewedBy            String?
  reviewDecision        String?
  reviewNotes           String?
  reviewedAt            DateTime?
  slaDeadline           DateTime

  verificationSession VerificationSession @relation(fields: [verificationSessionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reviewedBy])
}

// =======================
// Trust & Security Models
// =======================

enum CompanyVerificationStatus {
  pending
  verified
  rejected
}

model CompanyVerificationSession {
  id           String             @id @default(cuid())
  companyId    String
  userId       String
  status       VerificationStatus @default(pending)
  documentType String?

  // Legal identity submitted at start
  gstin     String?
  cinNumber String?

  // Document URLs
  registrationDocumentUrl String?
  incorporationCertUrl    String?

  apiValidationSuccessful Boolean?
  documentValid           Boolean?

  directorsMatched       Boolean?
  authorizationLetterUrl String?

  // AI verification result
  aiVerificationReason String?
  aiConfidenceScore    Float?

  failureReason String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([userId])
}

enum EventStatus {
  draft
  published
  completed
  cancelled
}

enum PayoutStatus {
  held
  processing
  released
  refunded
}

enum EscrowStatus {
  pending
  held
  refunded
  released
}

enum CheckInStatus {
  pending
  checked_in
}

model FraudReport {
  id      String  @id @default(cuid())
  eventId String
  userId  String
  reason  String
  details String?
  status  String  @default("pending")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId])
  @@index([userId])
}

model InvestmentProfile {
  id            String  @id @default(cuid())
  companyId     String  @unique
  fundingStage  String?
  askAmount     Float?
  pitchDeckUrl  String?
  financialsUrl String?
  isVerified    Boolean @default(false)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InvestorProfile {
  id                  String  @id @default(cuid())
  userId              String  @unique
  accreditationStatus      String  @default("pending")
  investmentThesis         String?
  identityVerified         Boolean @default(false)
  accreditationDocumentUrl String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DealRoom {
  id                 String  @id @default(cuid())
  companyId          String
  investorId         String
  status             String  @default("requested")
  ndaSigned          Boolean @default(false)
  ndaUrl             String?
  videoMeetingStatus String  @default("pending")
  brokerFlagged      Boolean @default(false)
  brokerReportReason String?

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  investor User    @relation(fields: [investorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, investorId])
  @@index([companyId])
  @@index([investorId])
}

// =======================
// Ownership Claim Models
// =======================

model CompanyOwnershipClaim {
  id         String @id @default(cuid())
  companyId  String
  claimantId String

  status             ClaimStatus              @default(pending)
  verificationMethod ClaimVerificationMethod?

  // Domain email verification
  domainEmail      String?
  domainVerifiedAt DateTime?

  // Document verification
  authorizationLetterUrl String?
  governmentIdUrl        String?
  documentVerifiedAt     DateTime?

  // GST/CIN cross-check
  submittedGstin String?
  submittedCin   String?
  gstNameMatch   Boolean?
  gstValidatedAt DateTime?

  // Admin review (fallback)
  adminDecision   String?
  adminNotes      String?
  adminReviewedAt DateTime?
  adminReviewedBy String?

  // Role to grant on approval
  requestedRole CompanyRoleType @default(owner)

  // Rejection
  rejectionReason String?

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  claimant User    @relation("ClaimantClaims", fields: [claimantId], references: [id], onDelete: Cascade)

  domainVerificationToken DomainVerificationToken?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, claimantId])
  @@index([companyId])
  @@index([claimantId])
  @@index([status])
}

model CompanyRole {
  id        String          @id @default(cuid())
  companyId String
  userId    String
  role      CompanyRoleType

  grantedBy String?
  grantedAt DateTime  @default(now())
  expiresAt DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
}

model DomainVerificationToken {
  id        String @id @default(cuid())
  claimId   String @unique
  email     String
  otpHash   String
  expiresAt DateTime

  claim CompanyOwnershipClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model FundingRound {
  id        String   @id @default(cuid())
  companyId String
  stage     String
  amount    Float
  date      DateTime
  investors String[]

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}
